    "skill",
    "xlsx",
    "spreadsheet",
    "openpyxl",
    "formualizer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StTronn/pi-sheets.git"
  },
  "bugs": {
    "url": "https://github.com/StTronn/pi-sheets/issues"
  },
  "homepage": "https://github.com/StTronn/pi-sheets#readme",
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "files": [
    "src",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
